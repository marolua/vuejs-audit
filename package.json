{
  "name": "vuejs-audit",
  "version": "1.0.0",
  "description": "Diagnose and fix performance, security, and architecture issues in your Vue.js/Nuxt codebase",
  "keywords": [
    "vue",
    "vue3",
    "vuejs",
    "nuxt",
    "nuxt3",
    "linter",
    "diagnostics",
    "performance",
    "security",
    "accessibility",
    "composition-api",
    "cli",
    "static-analysis",
    "code-quality"
  ],
  "homepage": "https://github.com/NiXouuuu/vuejs-audit#readme",
  "bugs": {
    "url": "https://github.com/NiXouuuu/vuejs-audit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiXouuuu/vuejs-audit.git"
  },
  "license": "MIT",
  "author": "Hugo",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vuejs-audit": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "postinstall": "node dist/postinstall.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
